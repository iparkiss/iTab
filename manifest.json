{
  "manifest_version": 3,
  "name": "iTab",
  "version": "1.5.3",
  "description": "iTab is A beautiful New-Tab page with customizable icons, search, and themes.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks"
  ],
  "host_permissions": [
    "https://pixabay.com/*",
    "https://suggestqueries.google.com/*"
  ],
  "action": {
    "default_title": "iTab",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
